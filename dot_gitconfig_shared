[core]
	autocrlf = input
	safecrlf = false
	symlinks = true
[alias]
	l = log --decorate
	ll = log --decorate --oneline
	lf = log --pretty=format:\"%C(auto,yellow)%h %C(auto,blue)%ad %C(auto,green)%<(7,trunc)%an%C(auto,reset)%s%C(auto,red)% gD% D\"
	s = status
	st = status -s -uno
	ss = status -s
	su = submodule update
	d = diff -w
	df = diff --name-only
	dd = diff
	co = commit
	con = commit --no-verify
	ch = checkout
	br = branch
	cp = cherry-pick --no-commit
	ps = push
	pl = pull
	f = fetch
	g = gc
